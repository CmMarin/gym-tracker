generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  password   String
  xp         Int      @default(0)
  weeklyXp   Int      @default(0)
  streakDays Int      @default(0)
  image      String? // User avatar
  createdAt  DateTime @default(now())

  // Relationships
  workoutPlans    WorkoutPlan[]
  workoutSchedule WorkoutSchedule?
  setLogs         SetLog[]
  activeWorkouts  ActiveWorkout[]
  workoutSessions WorkoutSession[]
  achievements    UserAchievement[]
  bodyWeightLogs  BodyWeightLog[]
  customExercises CustomExercise[]
  friends         Friendship[]      @relation("UserFriends")
  friendOf        Friendship[]      @relation("FriendUsers")
  coopMemberships CoopSessionMember[]
  notifications   Notification[]
  
  // Push Notifications
  pushNotificationsEnabled Boolean @default(false)
  pushSubscriptions       PushSubscription[]
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id])
  friend User @relation("FriendUsers", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  userId    String
  name      String
  dayOfWeek Int?
  createdAt DateTime @default(now())

  user            User             @relation(fields: [userId], references: [id])
  planExercises   PlanExercise[]
  activeWorkouts  ActiveWorkout[]
  workoutSessions WorkoutSession[]

  @@index([userId])
}

model Exercise {
  id       String  @id @default(cuid())
  name     String
  category String?

  planExercises PlanExercise[]
  setLogs       SetLog[]
}

model CustomExercise {
  id            String   @id @default(cuid())
  userId        String
  name          String
  category      String?
  targetMuscles String[] // e.g., ["Chest", "Triceps"]
  createdAt     DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  planExercises PlanExercise[]
  setLogs       SetLog[]

  @@index([userId])
}

model PlanExercise {
  id               String  @id @default(cuid())
  workoutPlanId    String
  exerciseId       String?
  customExerciseId String?
  targetSets       Int
  targetReps       Int

  workoutPlan    WorkoutPlan     @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise       Exercise?       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  customExercise CustomExercise? @relation(fields: [customExerciseId], references: [id], onDelete: Cascade)
}

model WorkoutSession {
  id              String   @id @default(cuid())
  userId          String
  workoutPlanId   String?
  totalXpEarned   Int      @default(0)
  durationMinutes Int      @default(0)
  completedAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  workoutPlan WorkoutPlan? @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)
  setLogs     SetLog[]

  @@index([userId])
  @@index([completedAt(sort: Desc)])
}

model SetLog {
  id               String   @id @default(cuid())
  userId           String
  sessionId        String
  exerciseId       String?
  customExerciseId String?
  setNumber        Int
  reps             Int
  weight           Float
  isWarmup         Boolean  @default(false)
  isPR             Boolean  @default(false)
  xpEarned         Int      @default(0)
  createdAt        DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id])
  session        WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise       Exercise?       @relation(fields: [exerciseId], references: [id])
  customExercise CustomExercise? @relation(fields: [customExerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([isPR])
}

model ActiveWorkout {
  id            String   @id @default(cuid())
  userId        String   @unique
  workoutPlanId String
  startTime     DateTime @default(now())
  state         Json // Stores current progression: current exercise index, completed sets, etc.

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id])
}

enum AchievementType {
  FIRST_WORKOUT
  STREAK_7_DAYS
  PR_HIT
  LIFT_1000_KG
  CLUB_100_KG
  NIGHT_OWL
  IRON_STREAK
  LEAGUE_GOLD
  LEAGUE_SILVER
  LEAGUE_BRONZE
}

model UserAchievement {
  id         String          @id @default(cuid())
  userId     String
  type       AchievementType
  achievedAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model BodyWeightLog {
  id        String   @id @default(cuid())
  userId    String
  weight    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model CoopSession {
  id           String             @id @default(cuid())
  inviteCode   String             @unique
  name         String
  status       String             @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  totalXp      Int                @default(0)
  goalXp       Int                @default(1000)
  createdAt    DateTime           @default(now())
  endedAt      DateTime?
  
  members      CoopSessionMember[]
}

model CoopSessionMember {
  id             String      @id @default(cuid())
  sessionId      String
  userId         String
  xpContributed  Int         @default(0)
  status         String      @default("IDLE") // LIFTING, RESTING, IDLE, COMPLETED
  currentExercise String?
  prsCount       Int         @default(0)
  volume         Float       @default(0)
  penalties      Int         @default(0)
  joinedAt       DateTime    @default(now())

  session        CoopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model WorkoutSchedule {
  id          String   @id @default(cuid())
  userId      String   @unique
  mondayId    String?
  tuesdayId   String?
  wednesdayId String?
  thursdayId  String?
  fridayId    String?
  saturdayId  String?
  sundayId    String?
  
  scope       String   @default("ONGOING") // ONGOING, THIS_WEEK, THIS_MONTH
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
